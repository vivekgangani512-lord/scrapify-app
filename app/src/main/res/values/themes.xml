<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.Scrapbid" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/primary_medium</item>
        <item name="colorPrimaryVariant">@color/primary</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="android:statusBarColor">@color/primary</item>
        <item name="android:navigationBarColor">@color/surface</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>
        <item name="textInputStyle">@style/Widget.Scrapbid.TextInput</item>
        <item name="materialButtonStyle">@style/Widget.Scrapbid.Button.Primary</item>
    </style>

    <!-- No action bar variant for auth screens -->
    <style name="Theme.Scrapbid.Splash" parent="Theme.Scrapbid">
        <item name="android:statusBarColor">@color/primary</item>
        <item name="android:windowFullscreen">false</item>
    </style>

    <!-- Buttons -->
    <style name="Widget.Scrapbid.Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/primary_medium</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:textSize">15sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="elevation">0dp</item>
    </style>

    <style name="Widget.Scrapbid.Button.Outline" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/primary_medium</item>
        <item name="android:textColor">@color/primary_medium</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:textSize">15sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="Widget.Scrapbid.Button.Accent" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/accent</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:textSize">15sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="elevation">0dp</item>
    </style>

    <!-- Text Input -->
    <style name="Widget.Scrapbid.TextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxStrokeColor">@color/outline</item>
        <item name="hintTextColor">@color/primary_medium</item>
        <item name="boxStrokeWidth">1.5dp</item>
    </style>

    <!-- Cards -->
    <style name="Widget.Scrapbid.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
        <item name="cardBackgroundColor">@color/surface</item>
    </style>

    <!-- Section Header -->
    <style name="TextAppearance.Scrapbid.SectionHeader" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:textAllCaps">true</item>
    </style>

</resources>
